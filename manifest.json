{
  "manifest_version": 2,
  "name": "Trinisphere",
  "version": "1.0",

  "description": "Cardsphere related improvements to many Magic sites",

  "icons": {
    "48": "icons/border-48.png"
  },
  "permissions": [
    "<all_urls>",
    "cookies",
    "activeTab",
    "notifications",
    "storage",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.cardsphere.com/send*"],
      "js": ["utils.js", "cardspheresend.js"]
    }
  ],
  "background": {
    "scripts": ["utils.js", "background.js"]
  },
  "options_ui": {
    "page": "options.html"
  }
}